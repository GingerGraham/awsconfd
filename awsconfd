# self-update / uninstall - unchanged in scope from the original delivery.
# Not addressed by the Part A/B review; self-update needs release
# infrastructure that doesn't exist yet, and the top-level `uninstall`
# command (distinct from `watch --uninstall` above, which IS implemented)
# was never in scope for either part. Left as clear, honest stubs.
# =============================================================================

cmd_self_update() {
    _err "self-update: not implemented yet (needs release infrastructure - GitHub Actions, checksums)"
    _info "for now: re-run install.sh, or 'git pull' and './install.sh --local' from a clone"
    return 1
}

cmd_uninstall() {
    local purge=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --purge) purge=1; shift ;;
            *) _err "uninstall: unknown option $1"; return 2 ;;
        esac
    done

    _watch_uninstall

    _info "to remove the binary: rm $(_self_path 2>/dev/null || echo "<path to awsconfd>")"

    if [[ $purge -eq 1 ]]; then
        if _confirm "restore the newest backup over $(_display_path "$AWSCONFD_CONFIG_FILE")?" 0; then
            local newest="" n=1
            while [[ -f "${AWSCONFD_CONFIG_FILE}.awsconfd-backup.${n}" ]]; do
                newest="${AWSCONFD_CONFIG_FILE}.awsconfd-backup.${n}"
                n=$((n + 1))
            done
            if [[ -n $newest ]]; then
                cp -p "$newest" "$AWSCONFD_CONFIG_FILE"
                _success "restored $(_display_path "$newest")"
            else
                _warn "no backups found"
            fi
        fi
        if _confirm "remove $(_display_path "$AWSCONFD_CONFIG_DIR") and $(_display_path "$SCHEME_FILE")?" 0; then
            rm -rf "$AWSCONFD_CONFIG_DIR"
            rm -f "$SCHEME_FILE"
            _success "removed config.d and scheme.conf"
        fi
    fi
    return 0
}

# =============================================================================
# HELP
# =============================================================================

_show_help() {
    cat << EOF
${PROG} - manage ~/.aws/config as a config.d directory

USAGE
    ${PROG} <command> [options]

DESCRIPTION
    AWS CLI has no native support for including multiple config files.
    ${PROG} keeps the real configuration as numbered INI fragments in
    ~/.aws/config.d/ and assembles them into ~/.aws/config, optionally
    rebuilding automatically whenever a fragment changes.

    Organisation-level SSO settings live in [sso-session] blocks, shared
    by every profile for that organisation. Identity- and role-level
    settings live in [profile] blocks. Splitting them across files is the
    point of the tool.

    ${PROG} never writes ~/.aws/credentials. It may read it, narrowly,
    to resolve source_profile names and compare profile sets with the AWS CLI.

COMMANDS
    init                  Create config.d, import any existing config, build
    add-sso [NAME]        Add or update an [sso-session] block
    add-profile [NAME]    Add or update a [profile] block
    apply --spec FILE|-   Create fragments from a spec file, then build
                          add --force-modern-layout to modernize legacy
                          explicit 2-digit layout entries in place
    migrate               Convert managed legacy 2-digit layout to 3-digit
                          use --dry-run to preview, --yes to skip confirm
    build                 Assemble ~/.aws/config from the fragments
    status                Show fragments, staleness, and watcher state
    doctor [--fix]        Validate the fragments; optionally repair
    list SUBJECT           List profiles | sso-sessions | fragments
                           add --with-credentials-file for profile diagnostics
    enable  FRAGMENT      Re-enable a disabled fragment
    disable FRAGMENT      Exclude a fragment from the build
    watch --install       Install the file watcher (systemd or launchd)
    watch --status        Show watcher state
    watch --uninstall     Remove the watcher
    hook bash|zsh         Print shell integration for eval
    self-update           Update ${PROG} in place (not yet implemented)
    uninstall [--purge]   Remove the watcher; optionally restore a backup

GLOBAL OPTIONS
    -h, --help            Show this help
    -V, --version         Print the version
    -q, --quiet           Suppress informational output
    -v, --verbose         Show extra diagnostic detail
    -y, --yes             Assume yes to confirmations
        --dry-run         Show what would change; write nothing
        --strict          Enforce the numbering scheme in scheme.conf
        --config-dir DIR  Override ~/.aws/config.d
        --config-file F   Override ~/.aws/config
        --no-color        Disable coloured output
    Global options are accepted before or after the command.

FILES
    ~/.aws/config                     Generated. Do not edit.
    ~/.aws/config.d/*.conf             The source of truth.
    ~/.config/awsconfd/scheme.conf    Your numbering scheme.

EXIT STATUS
    0  success
    1  runtime error
    2  usage error
    3  validation failure
    4  status --check: the config is stale

EXAMPLES
    # First run
    ${PROG} init
    ${PROG} add-sso personal
    ${PROG} add-profile personal-admin
    ${PROG} watch --install

    # Reproduce a setup on a new machine
    ${PROG} apply --spec ~/dotfiles/aws/multi-customer.spec.ini
    ${PROG} apply --spec ~/dotfiles/aws/legacy-layout.spec.ini --force-modern-layout

    # Convert an old managed 2-digit tree to the modern layout
    ${PROG} migrate --dry-run
    ${PROG} migrate --yes

    # Check before a rebuild
    ${PROG} doctor && ${PROG} build

See https://github.com/GingerGraham/awsconfd for full documentation.
EOF
    return 0
}

# =============================================================================
# GLOBAL ARGUMENT PARSING (review A6.1/A6.2/A6.3)
# =============================================================================
# Two-pass: sweep the entire argv for known GLOBAL flags wherever they
# appear (before or after the subcommand), applying them directly and
# removing them; the residue, in original relative order, is
# `command [command-opts]`. `--` stops global recognition (everything after
# it is passed through as residue verbatim). --no-provenance/--check/--fix/
# --no-import etc. are command-specific, not global, and are deliberately
# NOT matched here - they fall through to residue and are handled by each
# cmd_* function's own small parser.

_GLOBAL_RESIDUE=()

_extract_globals() {
    _GLOBAL_RESIDUE=()
    local seen_dashdash=0
    while [[ $# -gt 0 ]]; do
        if [[ $seen_dashdash -eq 1 ]]; then
            _GLOBAL_RESIDUE+=("$1")
            shift
            continue
        fi
        case "$1" in
            --)
                seen_dashdash=1
                shift
                ;;
            -h|--help)
                _show_help
                exit 0
                ;;
            -V|--version)
                _show_version
                exit 0
                ;;
            -q|--quiet) QUIET=1; shift ;;
            -v|--verbose) VERBOSE=1; shift ;;
            -y|--yes) ASSUME_YES=1; shift ;;
            --dry-run) DRY_RUN=1; shift ;;
            --strict) STRICT=1; shift ;;
            --no-color) NO_COLOR=1; shift ;;
            --non-interactive) NON_INTERACTIVE=1; shift ;;
            --config-dir)
                [[ $# -ge 2 ]] || { _err "--config-dir requires a value"; exit 2; }
                AWSCONFD_CONFIG_DIR="$2"
                AWSCONFD_CONFIG_DIR_EXPLICIT=1
                shift 2
                ;;
            --config-file)
                [[ $# -ge 2 ]] || { _err "--config-file requires a value"; exit 2; }
                AWSCONFD_CONFIG_FILE="$2"
                shift 2
                ;;
            *)
                _GLOBAL_RESIDUE+=("$1")
                shift
                ;;
        esac
    done
    return 0
}

# =============================================================================
# MAIN
# =============================================================================

main() {
    _init_colors
    _extract_globals "$@"
    _init_colors

    if [[ $AWSCONFD_CONFIG_DIR_EXPLICIT -eq 0 ]]; then
        AWSCONFD_CONFIG_DIR="$(dirname "$AWSCONFD_CONFIG_FILE")/config.d"
    fi
    AWSCONFD_STATE_DIR="${XDG_CONFIG_HOME}/awsconfd"
    SCHEME_FILE="${AWSCONFD_STATE_DIR}/scheme.conf"

    local cmd="${_GLOBAL_RESIDUE[0]:-}"
    if [[ -z $cmd ]]; then
        _show_help
        return 2
    fi
    local -a cmdargs=()
    if [[ ${#_GLOBAL_RESIDUE[@]} -gt 1 ]]; then
        cmdargs=("${_GLOBAL_RESIDUE[@]:1}")
    fi

    case "$cmd" in
        build)        cmd_build ${cmdargs[@]+"${cmdargs[@]}"} ;;
        init)         cmd_init ${cmdargs[@]+"${cmdargs[@]}"} ;;
        status)       cmd_status ${cmdargs[@]+"${cmdargs[@]}"} ;;
        list)         cmd_list ${cmdargs[@]+"${cmdargs[@]}"} ;;
        add-sso)      cmd_add_sso ${cmdargs[@]+"${cmdargs[@]}"} ;;
        add-profile)  cmd_add_profile ${cmdargs[@]+"${cmdargs[@]}"} ;;
        apply)        cmd_apply ${cmdargs[@]+"${cmdargs[@]}"} ;;
        migrate)      cmd_migrate ${cmdargs[@]+"${cmdargs[@]}"} ;;
        doctor)       cmd_doctor ${cmdargs[@]+"${cmdargs[@]}"} ;;
        enable)       cmd_enable ${cmdargs[@]+"${cmdargs[@]}"} ;;
        disable)      cmd_disable ${cmdargs[@]+"${cmdargs[@]}"} ;;
        watch)        cmd_watch ${cmdargs[@]+"${cmdargs[@]}"} ;;
        hook)         cmd_hook ${cmdargs[@]+"${cmdargs[@]}"} ;;
        self-update)  cmd_self_update ${cmdargs[@]+"${cmdargs[@]}"} ;;
        uninstall)    cmd_uninstall ${cmdargs[@]+"${cmdargs[@]}"} ;;
        *)
            _err "unknown command: $cmd"
            return 2
            ;;
    esac
}

main "$@"
